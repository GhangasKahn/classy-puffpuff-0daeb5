{
  "mcpServers": {
    "openscad": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "git+https://github.com/quellant/openscad-mcp.git",
        "openscad-mcp"
      ],
      "env": {
        "OPENSCAD_PATH": "/usr/bin/openscad",
        "MCP_TEMP_DIR": "/tmp/openscad-mcp",
        "MCP_CACHE_ENABLED": "true",
        "MCP_RENDER_TIMEOUT": "300"
      }
    }
  }
}
